{
  "name": "figma-music-bubble",
  "version": "0.3.1",
  "description": "Figma plugin that fills a Music Bubble component with iTunes track data.",
  "license": "MIT",
  "author": "Patrick Dugan",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pdugan20/figma-music-bubble.git"
  },
  "homepage": "https://github.com/pdugan20/figma-music-bubble#readme",
  "bugs": {
    "url": "https://github.com/pdugan20/figma-music-bubble/issues"
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore .superpowers",
    "style:check": "prettier --check .",
    "style:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "[ -d .git ] && npx simple-git-hooks || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@figma/plugin-typings": "^1.114.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.3",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no -- commitlint --edit \"$1\""
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,html,md}": [
      "prettier --write"
    ]
  }
}
